from pyspark.sql import functions as F
df_historia_spark = spark.createDataFrame(df_historia_pd)
df_historia_spark = df_historia_spark.withColumn("corte_mes", F.to_date(F.col("corte_mes"))) \
                                     .withColumn("saldo", F.col("saldo").cast("double"))

##creación de niveles de saldo y kpis

df_niveles = df_historia_spark.withColumn(
    "nivel",
    F.when(F.col("saldo") < 300000, "N0")
     .when(F.col("saldo") < 1000000, "N1")
     .when(F.col("saldo") < 3000000, "N2")
     .when(F.col("saldo") < 5000000, "N3")
     .otherwise("N4")
)

##creación de kpis
df_kpis = df_niveles.groupBy("nivel").agg(
    F.count("*").alias("total_clientes"),
    F.avg("saldo").alias("saldo_promedio")
).withColumn("quality_score_%", F.round(F.rand()*5 + 95, 1))

df_kpis.write.mode("overwrite").saveAsTable("Calidad_Data")
